# ═══════════════════════════════════════════════════════════
# INTACT.KZ — .htaccess
# ═══════════════════════════════════════════════════════════

# ── Запрет листинга директорий ──
Options -Indexes

# ── Кодировка по умолчанию ──
AddDefaultCharset UTF-8

# ── Защита конфиденциальных файлов ──
<FilesMatch "^(config\.php|\.env|\.git|composer\.(json|lock)|DEPLOY\.md)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# ── Блокировка вредоносных расширений (попытки залить шелл) ──
<FilesMatch "\.(php[0-9]?|phtml|phar|shtml|cgi|pl|py|rb|sh|bat|cmd|exe|dll|htaccess)$">
    <IfModule mod_authz_core.c>
        <RequireAll>
            Require all granted
        </RequireAll>
    </IfModule>
</FilesMatch>

# ── Защита /logs/ ──
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^logs/ - [F,L]
</IfModule>

# ── Блокировка SQL-инъекций и XSS в URL ──
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{QUERY_STRING} (union|select|insert|drop|delete|update|cast|exec|declare|script|alert|eval|base64|vbscript) [NC,OR]
    RewriteCond %{QUERY_STRING} (\.\./|\.\.\\|%2e%2e%2f|%252e%252e%252f) [NC]
    RewriteRule .* - [F,L]
</IfModule>

# ── Блокировка сканеров и ботов по User-Agent ──
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP_USER_AGENT} (curl|python|wget|scrapy|libwww|sqlmap|nikto|nmap|masscan|zgrab|dirbuster|gobuster|nuclei|hydra|metasploit) [NC]
    RewriteRule .* - [F,L]
</IfModule>

# ── Прямой доступ к send.php только через POST с нашего домена ──
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Разрешаем OPTIONS (preflight)
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^send\.php$ - [L]
    # Блокируем GET/HEAD к send.php
    RewriteCond %{REQUEST_METHOD} !POST
    RewriteRule ^send\.php$ - [F,L]
</IfModule>

# ── HTTPS редирект ──
<IfModule mod_rewrite.c>
    RewriteCond %{HTTPS} !=on
    RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]
</IfModule>

# ── www → без www ──
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_HOST} ^www\.intact\.kz [NC]
    RewriteRule ^(.*)$ https://intact.kz/$1 [R=301,L]
</IfModule>

# ── Обработка 404 ──
ErrorDocument 404 /404.php
ErrorDocument 403 /404.php

# ═══════════════════════════════════════════════════════════
# GZIP-сжатие
# ═══════════════════════════════════════════════════════════
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ═══════════════════════════════════════════════════════════
# Кеширование
# ═══════════════════════════════════════════════════════════
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 day"

    # Шрифты — 30 дней
    ExpiresByType font/woff2                    "access plus 30 days"
    ExpiresByType font/woff                     "access plus 30 days"
    ExpiresByType application/font-woff2        "access plus 30 days"
    ExpiresByType application/font-woff         "access plus 30 days"

    # CSS / JS — 7 дней
    ExpiresByType text/css                      "access plus 7 days"
    ExpiresByType text/javascript               "access plus 7 days"
    ExpiresByType application/javascript        "access plus 7 days"

    # Изображения — 30 дней
    ExpiresByType image/jpeg                    "access plus 30 days"
    ExpiresByType image/png                     "access plus 30 days"
    ExpiresByType image/svg+xml                 "access plus 30 days"
    ExpiresByType image/webp                    "access plus 30 days"
    ExpiresByType image/x-icon                  "access plus 30 days"

    # HTML — без кеша
    ExpiresByType text/html                     "access plus 0 seconds"
</IfModule>

# ── Cache-Control для HTML ──
<IfModule mod_headers.c>
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>
</IfModule>

# ═══════════════════════════════════════════════════════════
# Заголовки безопасности
# ═══════════════════════════════════════════════════════════
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://mc.yandex.ru https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://mc.yandex.ru; connect-src 'self' https://mc.yandex.ru; frame-src 'self' https://www.google.com https://2gis.kz"
</IfModule>

# ═══════════════════════════════════════════════════════════
# ETags — отключить (достаточно Expires)
# ═══════════════════════════════════════════════════════════
<IfModule mod_headers.c>
    Header unset ETag
</IfModule>
FileETag None
